<style>
    article a {
        background:#111;
        padding: 10px 16px;
        transition: all 0.3s ease;
    }
    article a:hover {
        scale:1.2;
    }
    #footer { 
        background-color:white;
    }
    .wave {
        position:absolute;
        bottom:0; left:0;
        background-image: url(/assets/wave.webp);
        background-size: 1000px 160px;
        height:160px;
        width:100%;
        z-index:-999;
    }
    .wave1{ 
        opacity:1;
        animation-delay: -3s;
        animation: wave 17s ease-in-out infinite;
    }
    .wave2{ 
        opacity:0.5;
        animation-delay: 5s;
        animation: wave 12s ease-in-out infinite;
    }
    .wave3{ 
        opacity:0.7;
        animation-delay: -2s;
        animation: wave 10s linear infinite reverse;
    }
    @keyframes wave {
        0% {
            background-position: 0;
        }
        100% {
            background-position: 1000px;
        }
    }
</style>