---
const { title, image, description, url, name, lenguajes } = Astro.props;
---

<main class="flex flex-col gap-3 p-6 prose">
    <h2 class="text-2xl text-center underline decoration-2">{title}</h2>
    <img src={image} alt={title} class="rounded-2xl h-55"/>
    <section class="flex flex-col gap-2">
        <p class="font-medium">{description}</p>
        <div class="flex justify-evenly items-center">
            <div class="flex gap-3">
                <div class="flex gap-3">
                  {lenguajes && lenguajes.map((icon) => (
                    <img src={icon} alt="" class="size-7" />
                  ))}
                </div>
            </div>
            <a href={url} class="button">{name}</a>
        </div>
    </section>
</main>

<style>
    main {
        background-color: rgba(0, 0, 0, 0.353);
		background-attachment: blur(1em);
		color: #fff;
        border-radius: 20px;
        border: 1.5px solid #fafafa10;
        box-shadow: 6px 8px 17px 0px rgba(0, 0, 0, 0.63);
    }
    .button {
        background: rgba(17, 26, 34, 0.377);
		background-attachment: blur(1em);
		color: #fff;
        border-radius: 16px;
        border: 1.5px solid #fafafa10;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.7), 0 1px rgba(255, 255, 255, 0.08);
        padding: 6px 12px;
    }
</style>
